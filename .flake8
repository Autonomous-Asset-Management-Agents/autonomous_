[flake8]
# ADR-CI-01: Flake8 hard gates — only block on real correctness issues.
# Style issues (E1xx line length, W2xx whitespace) and star-import noise
# from vendored libs are excluded. Remove entries as technical debt is cleared.

max-line-length = 120

exclude =
    .venv,
    venv,
    venv_new,
    __pycache__,
    # vendored pandas-ta fork — star-import style is upstream design, not our code
    pandas-ta,

# F403/F405: star imports — blocked in new code but vendored lib (pandas_ta_classic)
# uses them internally. Suppress until the vendor is replaced with pandas-ta proper.
# E402: module-level import not at top — triggered by conditional imports (Vertex AI,
#        optional deps). Acceptable pattern for optional enterprise integrations.
# E501: line too long — 120 char limit is enforced by max-line-length above;
#        pre-existing violations suppressed here until cleaned up (Sprint backlog).
# F401: imported but unused — several modules do star-imports; clean up separately.
# F541: f-string without placeholder — cosmetic, non-blocking.
# W191/W291/W293: whitespace — non-blocking, clean up with `black` separately.
per-file-ignores =
    # vendored utility wrapper — star imports are design, not our code
    core/utils/*.py: F401,F403,F405,E402

# Global ignores for pre-existing violations tracked in Sprint-1 backlog
# DO NOT ADD NEW CODES HERE — fix the code instead.
extend-ignore =
    E203,
    E302,
    E306,
    E401,
    E402,
    E501,
    F401,
    F403,
    F405,
    F541,
    F811,
    F824,
    F841,
    W191,
    W291,
    W293,

# These are ALWAYS blocking (never ignore):
# E711 comparison to None (== None instead of is None)
# E712 comparison to False
# E722 bare except
# E741 ambiguous variable name
# F821 undefined name
# W605 invalid escape sequence
