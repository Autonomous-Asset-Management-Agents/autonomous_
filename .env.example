# AAAgents OSS — Environment Template
# Copy this file to `.env.oss` and fill in the required values before running
# `docker compose -f docker-compose.oss.yml up`.
#
# REQUIRED values (compose will refuse to start if missing):
#   POSTGRES_PASSWORD
#
# All other values have safe defaults; override only if you need to.

# ─── Database ──────────────────────────────────────────────────────────────
# REQUIRED. Use a strong, unique password. Postgres binds to loopback only
# (127.0.0.1:5432), so this guards against same-host process access and
# accidental remote exposure if you later change the bind address.
POSTGRES_PASSWORD=

# Optional overrides (defaults shown):
# POSTGRES_USER=oss
# POSTGRES_DB=aaagents

# ─── Redis ─────────────────────────────────────────────────────────────────
# Optional. Default suffices for local dev; change for shared/exposed setups.
# REDIS_PASSWORD=aaa-local-dev-password

# ─── Broker (Alpaca paper-trading) ─────────────────────────────────────────
# Optional. Without these the bot boots in offline mode (no live broker calls).
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Round Table Plugins ───────────────────────────────────────────────────
# Plugin loading is DENY-BY-DEFAULT. Setting ALLOW_UNTRUSTED_PLUGINS=true
# enables dynamic import of every .py file in ROUND_TABLE_PLUGINS_DIR at
# engine boot — that is effectively arbitrary code execution as the
# container user. See docs/oss/ARCHITECTURE.md §5 and ADR-OSS1.
#
# Only enable if you wrote (or carefully reviewed) every plugin file yourself.
# ALLOW_UNTRUSTED_PLUGINS=false
# ROUND_TABLE_PLUGINS_DIR=/app/app/plugins/round_table

# ─── Internal Service Authentication ─────────────────────────────────────────
# REQUIRED — but intentionally left blank here.
# Run `bash setup.sh` (macOS/Linux/Git Bash) or `.\setup.ps1` (Windows PowerShell)
# to have this value generated automatically with a cryptographically secure random
# string. You should NOT set this manually unless you know what you are doing.
#
# What it is: An HMAC-SHA256 shared secret used by the Public API to sign
# every request it proxies to the Backend Engine. The engine verifies the
# signature before processing. This prevents any process on the host from
# bypassing the auth layer by talking directly to port 8001.
#
# PROXY_ENGINE_SHARED_SECRET=   # <-- generated by setup.sh, do not commit

